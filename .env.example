# =============================================================================
# Backend environment variables — TEMPLATE
# =============================================================================
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# `.env` is gitignored; this template (with placeholders only) is committed.
# Never commit real secrets.
# =============================================================================


# ---------- Database ----------
# Postgres connection string. The async engine derives a +asyncpg variant
# automatically; sslmode=require works but is stripped from the asyncpg URL.
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require


# ---------- Groq LLM ----------
# Get your key at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
# Optional. Defaults to llama-3.3-70b-versatile if unset.
GROQ_MODEL=openai/gpt-oss-120b


# ---------- JWT auth ----------
# Used to sign access tokens issued by /api/auth/login and /api/auth/signup.
# Generate a strong secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60


# ---------- Logging ----------
LOG_LEVEL=INFO
